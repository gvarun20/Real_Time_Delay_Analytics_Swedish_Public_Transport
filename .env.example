# Docker Compose project name (container prefix: transit-delay-pipeline-*)
COMPOSE_PROJECT_NAME=transit-delay-pipeline

# --- Trafiklab API keys (separate keys per product on developer.trafiklab.se) ---
# IMPORTANT: STATIC_FEED and REALTIME_FEED must be from the SAME feed family, or
# trip_id/route_id/stop_id won't match between static and realtime data and the
# transform join in jobs/transform_gtfs.py will always return 0 rows. See ADR-003.
#
# Matching pairs:
#   STATIC_FEED=gtfs_sweden_3  + REALTIME_FEED=gtfs_sweden   (needs "GTFS Sweden 3 Realtime" key)
#   STATIC_FEED=gtfs_regional  + REALTIME_FEED=gtfs_regional (needs "GTFS Regional Static data" key)

# Static:  from "GTFS Sweden 3 Static data"  (or use GTFS Regional Static + STATIC_FEED=gtfs_regional)
TRAFIKLAB_STATIC_API_KEY=your_static_key_here

# Realtime: from "GTFS Sweden 3 Realtime" (must match STATIC_FEED's family — see note above)
TRAFIKLAB_REALTIME_API_KEY=your_realtime_key_here

# Optional fallback if you only have one key
TRAFIKLAB_API_KEY=

# Static feed type: gtfs_sweden_3 (default) | gtfs_regional
STATIC_FEED=gtfs_sweden_3

# Realtime feed type: gtfs_sweden (default, matches gtfs_sweden_3 static) | gtfs_regional (matches gtfs_regional static)
REALTIME_FEED=gtfs_sweden

# Operator abbreviation (sl = Stockholm, otraf = Östgötatrafiken)
OPERATOR=sl
OPERATOR_NAME=SL

# Paths (defaults work for local + Docker)
DATA_RAW_DIR=data/raw
PROJECT_ROOT=.

# Analytics Postgres (star schema)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=transit_dw
POSTGRES_USER=transit
POSTGRES_PASSWORD=transit

# Airflow (Docker)
AIRFLOW_UID=50000
